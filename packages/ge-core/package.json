{
  "name": "@antv/ge-core",
  "version": "2.0.0-alpha.0",
  "description": "Core module of GE - A graph editor built on AntV/G DOM model",
  "keywords": [
    "antv",
    "g",
    "graph",
    "graph-editor",
    "diagram",
    "flowchart",
    "visualization",
    "node",
    "edge"
  ],
  "license": "MIT",
  "author": "AntV <antv@alibaba-inc.com>",
  "homepage": "https://g.antv.antgroup.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/antvis/GE"
  },
  "bugs": {
    "url": "https://github.com/antvis/GE/issues"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@antv/g-canvas": "^2.0.0",
    "@antv/g-lite": "^2.0.0",
    "@antv/g-plugin-dragndrop": "^2.0.0",
    "@antv/g-svg": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
